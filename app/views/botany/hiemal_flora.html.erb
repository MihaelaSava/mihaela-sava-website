<section class="py-16 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <a href="<%= botany_projects_path %>" class="text-sm text-emerald-700 hover:text-emerald-900 font-medium mb-4 inline-flex items-center gap-1">← Back to Botany Projects</a>
    <h1 class="text-4xl font-bold text-gray-900 mt-3 mb-3">Hiemal Flora of Romania</h1>
    <p class="text-lg text-gray-600 leading-relaxed max-w-3xl mb-10">
      The <em>hiemal</em> season (November – February) is a time of rest for most plants, but a few species brave the cold and bloom in winter.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Viburnum tinus -->
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-blue-50 to-gray-100 flex items-center justify-center">
          <span class="text-6xl">💙❄️</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Laur sălbatic</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Viburnum tinus</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Laurustinus — evergreen shrub with pinkish-white flowers, blooming even in mild winter spells.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Adoxaceae</span>
            <span class="text-xs bg-blue-50 text-blue-700 px-2 py-0.5 rounded-full">Dec–Feb</span>
          </div>
        </div>
      </div>
      <!-- Erica carnea -->
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-pink-50 to-fuchsia-100 flex items-center justify-center">
          <span class="text-6xl">🌸❄️</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Iarbă neagră</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Erica carnea</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Winter heath — low shrub with pink flowers, blooming from late winter into early spring.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Ericaceae</span>
            <span class="text-xs bg-blue-50 text-blue-700 px-2 py-0.5 rounded-full">Jan–Mar</span>
          </div>
        </div>
      </div>
      <!-- Helleborus niger -->
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-white to-gray-200 flex items-center justify-center">
          <span class="text-6xl">🤍❄️</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Trandafirul Crăciunului</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Helleborus niger</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Christmas rose — white flowers that can bloom outdoors in December and January.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Ranunculaceae</span>
            <span class="text-xs bg-blue-50 text-blue-700 px-2 py-0.5 rounded-full">Dec–Jan</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
