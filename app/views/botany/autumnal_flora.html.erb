<section class="py-16 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <a href="<%= botany_projects_path %>" class="text-sm text-emerald-700 hover:text-emerald-900 font-medium mb-4 inline-flex items-center gap-1">← Back to Botany Projects</a>
    <h1 class="text-4xl font-bold text-gray-900 mt-3 mb-3">Autumnal Flora of Romania</h1>
    <p class="text-lg text-gray-600 leading-relaxed max-w-3xl mb-10">
      The <em>autumnal</em> season (September – October) is marked by late-blooming wildflowers and the first signs of dormancy.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Colchicum autumnale -->
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-purple-50 to-pink-100 flex items-center justify-center">
          <span class="text-6xl">💜🍂</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Brândușa de toamnă</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Colchicum autumnale</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Autumn crocus — lilac flowers blooming in meadows after most plants have faded.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Colchicaceae</span>
            <span class="text-xs bg-orange-50 text-orange-700 px-2 py-0.5 rounded-full">Sep–Oct</span>
          </div>
        </div>
      </div>
      <!-- Gentiana asclepiadea -->
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-blue-50 to-indigo-100 flex items-center justify-center">
          <span class="text-6xl">💙🌾</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Ghințură</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Gentiana asclepiadea</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Willow gentian — deep blue flowers in mountain clearings and forest edges.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Gentianaceae</span>
            <span class="text-xs bg-orange-50 text-orange-700 px-2 py-0.5 rounded-full">Aug–Sep</span>
          </div>
        </div>
      </div>
      <!-- Cyclamen hederifolium -->
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-pink-50 to-rose-100 flex items-center justify-center">
          <span class="text-6xl">🌸🍁</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Ciclamă</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Cyclamen hederifolium</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Ivy-leaved cyclamen — pink flowers and marbled leaves in shady woodlands.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Primulaceae</span>
            <span class="text-xs bg-orange-50 text-orange-700 px-2 py-0.5 rounded-full">Sep–Oct</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
