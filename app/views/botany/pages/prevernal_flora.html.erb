<section class="py-16 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-12">
      <a href="<%= botany_projects_path %>" class="text-sm text-emerald-700 hover:text-emerald-900 font-medium mb-4 inline-flex items-center gap-1">
        ← Back to Botany Projects
      </a>
      <h1 class="text-4xl font-bold text-gray-900 mt-3 mb-3">Prevernal Flora of Romania</h1>
      <p class="text-lg text-gray-600 leading-relaxed max-w-3xl">
        The <em>prevernal</em> period (late February – March) marks the first botanical stirrings of the year. 
        These hardy wildflowers break through frost and snow, painting Romanian meadows, forests and hillsides 
        with delicate colour before true spring arrives.
      </p>
    </div>

    <!-- Plant Cards Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

      <%# ── Helleborus purpurascens ── %>
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 overflow-hidden bg-purple-50">
          <img src="<%= asset_path('botany/Hellebrus_purpurascens.jpeg') %>" alt="Helleborus purpurascens (Purple hellebore)" class="object-cover h-48 w-full" loading="lazy">
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Spânz</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Helleborus purpurascens</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            The purple hellebore, native to the Carpathians. Thrives in beech and hornbeam forests on calcareous soils,
            producing nodding purple-green flowers.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Ranunculaceae</span>
            <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Feb–Apr</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
