<section class="py-16 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-12">
      <a href="<%= botany_projects_path %>" class="text-sm text-emerald-700 hover:text-emerald-900 font-medium mb-4 inline-flex items-center gap-1">
        ← Back to Botany Projects
      </a>
      <h1 class="text-4xl font-bold text-gray-900 mt-3 mb-3">Prevernal Flora of Romania</h1>
      <p class="text-lg text-gray-600 leading-relaxed max-w-3xl">
        The <em>prevernal</em> period (late February – March) marks the first botanical stirrings of the year. 
        These hardy wildflowers break through frost and snow, painting Romanian meadows, forests and hillsides 
        with delicate colour before true spring arrives.
      </p>
    </div>

    <!-- Plant Cards Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

      <%# ── Galanthus nivalis ── %>
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-green-50 to-emerald-100 flex items-center justify-center">
          <span class="text-6xl">❄️🌸</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Ghiocel</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Galanthus nivalis</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            The common snowdrop — Romania's beloved harbinger of spring.
            Found in deciduous forests and shaded meadows, often flowering while snow still covers the ground.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Amaryllidaceae</span>
            <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Feb–Mar</span>
          </div>
        </div>
      </div>

      <%# ── Helleborus purpurascens ── %>
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-purple-50 to-fuchsia-100 flex items-center justify-center">
          <span class="text-6xl">💜🌿</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Spânz</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Helleborus purpurascens</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            The purple hellebore, native to the Carpathians. Thrives in beech and hornbeam forests on calcareous soils,
            producing nodding purple-green flowers.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Ranunculaceae</span>
            <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Feb–Apr</span>
          </div>
        </div>
      </div>

      <%# ── Crocus vernus ── %>
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-violet-50 to-yellow-50 flex items-center justify-center">
          <span class="text-6xl">💛💜</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Brândușa de primăvară</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Crocus vernus</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Spring crocus — carpets sub-alpine meadows in the Carpathians with purple, white and yellow blooms
            as soon as the snow retreats.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Iridaceae</span>
            <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Feb–Mar</span>
          </div>
        </div>
      </div>

      <%# ── Scilla bifolia ── %>
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-blue-50 to-sky-100 flex items-center justify-center">
          <span class="text-6xl">💙🌼</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Viorele</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Scilla bifolia</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Alpine squill — forms striking blue carpets in oak and beech forests across the Romanian hills,
            one of the earliest woodland flowers.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Asparagaceae</span>
            <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Feb–Mar</span>
          </div>
        </div>
      </div>

      <%# ── Hepatica nobilis ── %>
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-indigo-50 to-blue-100 flex items-center justify-center">
          <span class="text-6xl">🔵🍃</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Crucea voinicului</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Hepatica nobilis</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Common hepatica — a jewel of early spring woods. Its vivid blue-violet flowers appear before
            the new leaves, often on lime-rich forest floors.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Ranunculaceae</span>
            <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Mar–Apr</span>
          </div>
        </div>
      </div>

      <%# ── Corydalis solida ── %>
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-pink-50 to-rose-100 flex items-center justify-center">
          <span class="text-6xl">🩷🌸</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Brebenei</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Corydalis solida</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Solid-tubered corydalis — a spring ephemeral with dense pink-purple flower clusters. Widespread in
            Romanian deciduous forests on rich, moist soils.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Papaveraceae</span>
            <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Mar–Apr</span>
          </div>
        </div>
      </div>

      <%# ── Tussilago farfara ── %>
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-yellow-50 to-amber-100 flex items-center justify-center">
          <span class="text-6xl">🌻</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Podbal</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Tussilago farfara</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Coltsfoot — bright yellow daisy-like flowers appear on bare stems before the large round leaves.
            Common on clay-rich roadsides and stream banks throughout Romania.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Asteraceae</span>
            <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Feb–Mar</span>
          </div>
        </div>
      </div>

      <%# ── Eranthis hyemalis ── %>
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-yellow-50 to-lime-100 flex items-center justify-center">
          <span class="text-6xl">✨🌼</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Măselariță</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Eranthis hyemalis</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Winter aconite — cheerful golden cups surrounded by a ruff of green bracts. One of the very first
            flowers to bloom, sometimes pushing up through frozen ground.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Ranunculaceae</span>
            <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Feb–Mar</span>
          </div>
        </div>
      </div>

      <%# ── Leucojum vernum ── %>
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-green-50 to-teal-100 flex items-center justify-center">
          <span class="text-6xl">🤍🌿</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Ghiocelul mare</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Leucojum vernum</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Spring snowflake — resembles a larger, sturdier snowdrop with green-tipped bell-shaped flowers.
            Prefers wet meadows and stream-sides in the Romanian Carpathians.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Amaryllidaceae</span>
            <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full">Feb–Mar</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
