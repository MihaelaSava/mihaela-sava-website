<section class="py-16 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <a href="<%= botany_projects_path %>" class="text-sm text-emerald-700 hover:text-emerald-900 font-medium mb-4 inline-flex items-center gap-1">← Back to Botany Projects</a>
    <h1 class="text-4xl font-bold text-gray-900 mt-3 mb-3">Estival Flora of Romania</h1>
    <p class="text-lg text-gray-600 leading-relaxed max-w-3xl mb-10">
      The <em>estival</em> season (June – August) is the peak of botanical diversity, with meadows, forests, and wetlands in full bloom.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Centaurea cyanus -->
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-blue-50 to-sky-100 flex items-center justify-center">
          <span class="text-6xl">💙🌾</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Albăstrele</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Centaurea cyanus</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Cornflower — iconic blue wildflower of summer wheat fields.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Asteraceae</span>
            <span class="text-xs bg-yellow-50 text-yellow-700 px-2 py-0.5 rounded-full">Jun–Aug</span>
          </div>
        </div>
      </div>
      <!-- Lilium martagon -->
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-pink-50 to-rose-100 flex items-center justify-center">
          <span class="text-6xl">🌸</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Crin de pădure</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Lilium martagon</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Martagon lily — elegant pink flowers with recurved petals, found in mountain forests.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Liliaceae</span>
            <span class="text-xs bg-yellow-50 text-yellow-700 px-2 py-0.5 rounded-full">Jun–Jul</span>
          </div>
        </div>
      </div>
      <!-- Dactylorhiza maculata -->
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-purple-50 to-fuchsia-100 flex items-center justify-center">
          <span class="text-6xl">💜🌿</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Orhidee de baltă</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Dactylorhiza maculata</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Heath spotted-orchid — purple-pink spikes in wet meadows and marshes.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Orchidaceae</span>
            <span class="text-xs bg-yellow-50 text-yellow-700 px-2 py-0.5 rounded-full">Jun–Aug</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
