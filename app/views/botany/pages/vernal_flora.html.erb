<section class="py-16 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <a href="<%= botany_projects_path %>" class="text-sm text-emerald-700 hover:text-emerald-900 font-medium mb-4 inline-flex items-center gap-1">← Back to Botany Projects</a>
    <h1 class="text-4xl font-bold text-gray-900 mt-3 mb-3">Vernal Flora of Romania</h1>
    <p class="text-lg text-gray-600 leading-relaxed max-w-3xl mb-10">
      The <em>vernal</em> season (March – May) brings a burst of color and diversity to Romanian landscapes. Explore some of the most iconic spring wildflowers.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Anemone nemorosa -->
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-pink-50 to-white flex items-center justify-center">
          <span class="text-6xl">🤍🌸</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Floarea Paștelui</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Anemone nemorosa</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Wood anemone — delicate white flowers carpeting forests in early spring.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Ranunculaceae</span>
            <span class="text-xs bg-green-50 text-green-700 px-2 py-0.5 rounded-full">Mar–May</span>
          </div>
        </div>
      </div>
      <!-- Primula veris -->
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-yellow-50 to-lime-100 flex items-center justify-center">
          <span class="text-6xl">🌼</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Ciuboțica-cucului</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Primula veris</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Cowslip — clusters of fragrant yellow bells in meadows and forest edges.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Primulaceae</span>
            <span class="text-xs bg-green-50 text-green-700 px-2 py-0.5 rounded-full">Apr–May</span>
          </div>
        </div>
      </div>
      <!-- Pulsatilla montana -->
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
        <div class="h-48 bg-linear-to-br from-purple-50 to-indigo-100 flex items-center justify-center">
          <span class="text-6xl">💜🌿</span>
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-gray-900">Cucută</h3>
          <p class="text-sm text-emerald-700 italic mb-2">Pulsatilla montana</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Mountain pasqueflower — silky purple blooms in dry grasslands and hills.
          </p>
          <div class="mt-3 flex flex-wrap gap-1.5">
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">Ranunculaceae</span>
            <span class="text-xs bg-green-50 text-green-700 px-2 py-0.5 rounded-full">Mar–Apr</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
