<section class="mx-auto max-w-4xl px-6 py-20">
  <header class="mb-16">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900">
      Dev Etymology
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-gray-600">
      <%= t('dev.etymology.subtitle') %>
    </p>
  </header>

  <%= render Dev::EtymologyEntryComponent.new(
    term: "sudo",
    expansion: "super user do",
    category: "command",
    description: t('dev.etymology.sudo_desc'),
    example: "sudo apt update",
    note: "Use with care — this command can modify critical system files."
  ) %>

  <%= render Dev::EtymologyEntryComponent.new(
    term: "bash",
    expansion: "Bourne Again Shell",
    category: "shell",
    description: t('dev.etymology.bash_desc'),
    example: "bash --version"
  ) %>

  <div class="mt-8 p-5 bg-yellow-50 border-l-4 border-yellow-400 rounded shadow-sm">
    <%= simple_format(t('dev.etymology.bash_legend')) %>
  </div>
</section>
