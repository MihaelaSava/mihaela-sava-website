<main class="home">
  <div
    class="domain-slider"
    data-controller="domain-slider"
    style="
      --left-domain: url('<%= asset_path('background.jpg') %>');
      --right-domain: url('<%= asset_path('background_2.jpg') %>');
    "
  >
    <!-- Right side: Code -->
    <div class="domain-slider__base"></div>

    <!-- Left side: Botany (revealed by sliding) -->
    <div
      class="domain-slider__overlay"
      data-domain-slider-target="overlay"
    >
      <div class="domain-slider__text">
        <h1 class="domain-slider__title">
          My work is beginning to bloom.
        </h1>

        <p class="domain-slider__contact">
          📩 <a href="mailto:contact@mihaela-sava.com">
            contact@mihaela-sava.com
          </a>
        </p>
      </div>
    </div>

    <input
      type="range"
      min="0"
      max="100"
      value="50"
      class="domain-slider__range"
      data-domain-slider-target="range"
      data-action="input->domain-slider#slide"
      aria-label="Slide between botany and code"
    />

    <div
      class="domain-slider__handle"
      data-domain-slider-target="handle"
      aria-hidden="true">
    </div>
  </div>
</main>
