<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Mihaela Sava" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%= favicon_link_tag "favicon.ico" %>
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Tailwind CSS built to app/assets/builds/application.css %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="">
    <%= render NavbarComponent.new(
      active_path: request.path,
      current_user: defined?(current_user) ? current_user : nil,
      items: [
        { name: t('navbar.home'), path: root_path },
        { name: t('navbar.botany_projects'), path: "/botany-projects" },
        { name: t('navbar.dev_projects'), path: "/dev-projects" },
        { name: t('navbar.about'), path: about_path }
      ]
    ) %>

    <main class="min-h-[80vh]">
      <%= yield %>
      <script>
        // Set language switchers to current language
        document.addEventListener('DOMContentLoaded', function() {
          if (window.getLanguage) {
            var lang = getLanguage();
            var sel = document.getElementById('language-switcher');
            if (sel) sel.value = lang;
            var selMobile = document.getElementById('language-switcher-mobile');
            if (selMobile) selMobile.value = lang;
          }
        });
      </script>
    </main>

    <footer class="border-t border-gray-200 text-sm text-gray-600 text-center py-4">
      © <%= Time.current.year %> Mihaela Sava · Botanist & Developer 🌿
    </footer>
  </body>
</html>
