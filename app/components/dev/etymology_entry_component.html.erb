<article class="mb-10 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h2 class="text-2xl font-semibold text-gray-900">
        <%= @term %>
      </h2>

      <p class="mt-1 text-sm italic text-gray-500">
        <%= @expansion %>
      </p>
    </div>

    <span class="rounded-full bg-gray-100 px-3 py-1 text-sm text-gray-600">
      <%= @category %>
    </span>
  </div>

  <p class="mt-4 text-gray-700 leading-relaxed">
    <%= @description %>
  </p>

  <% if @example.present? %>
    <pre class="mt-4 rounded-xl bg-gray-900 p-4 text-sm text-gray-100 overflow-x-auto">
      <code><%= @example %></code>
    </pre>
  <% end %>

  <% if @note.present? %>
    <p class="mt-4 text-sm text-gray-500">
      ⚠️ <%= @note %>
    </p>
  <% end %>
</article>
