<nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16 items-center">
      <!-- Brand -->
      <div class="flex-shrink-0">
        <%= link_to @brand_name, root_path, class: "text-xl font-bold text-gray-900 hover:text-gray-700" %>
      </div>

      <!-- Menu -->
      <div class="hidden md:flex items-center space-x-6">
        <% visible_items.each do |item| %>
          <% classes = "text-gray-700 hover:text-black font-medium" %>
          <% classes << " border-b-2 border-black pb-1" if active?(item[:path]) %>

          <%= link_to item[:name], item[:path], class: classes, "aria-current": (active?(item[:path]) ? "page" : nil) %>
        <% end %>

        <!-- Language switcher -->
        <details class="relative group">
          <summary class="list-none cursor-pointer flex items-center gap-2 pl-4 border-l border-gray-300 text-sm font-medium text-gray-700 hover:text-black">
            <% current_language = {
              en: { label: "English", flag: "🇬🇧" },
              ro: { label: "Română", flag: "🇷🇴" },
              fr: { label: "Français", flag: "🇫🇷" }
            }[I18n.locale.to_sym] %>

            <span><%= current_language[:flag] %></span>
            <span><%= I18n.locale.to_s.upcase %></span>
            <svg class="w-4 h-4 text-gray-500 group-open:rotate-180 transition-transform duration-200"
                 fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>

          <div class="absolute right-0 mt-3 w-44 bg-white border border-gray-200 rounded-xl shadow-xl py-1 z-50">
            <% {
              en: { label: "English", flag: "🇬🇧" },
              ro: { label: "Română", flag: "🇷🇴" },
              fr: { label: "Français", flag: "🇫🇷" }
            }.each do |locale, data| %>
              <% if locale == I18n.locale.to_sym %>
                <div class="flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-black bg-gray-50">
                  <span><%= data[:flag] %></span>
                  <span><%= data[:label] %></span>
                </div>
              <% else %>
                <%= link_to url_for(locale: locale),
                            class: "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-black transition-colors duration-150" do %>
                  <span><%= data[:flag] %></span>
                  <span><%= data[:label] %></span>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </details>
      </div>

      <!-- Mobile menu toggle -->
      <div class="md:hidden">
        <details class="relative group">
          <summary class="cursor-pointer flex items-center justify-center w-10 h-10 rounded-lg hover:bg-gray-100 transition-colors duration-200" aria-label="Menu">
            <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </summary>

          <div class="absolute right-0 mt-2 w-56 bg-white border border-gray-200 rounded-xl shadow-xl py-1 z-50">
            <% visible_items.each do |item| %>
              <%= link_to item[:name], item[:path],
                          class: "block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-black transition-colors duration-150" %>
            <% end %>

            <!-- Mobile language switcher -->
            <div class="border-t border-gray-100 mt-1 pt-1">
              <div class="px-4 py-2 text-xs font-semibold uppercase tracking-wide text-gray-400">
                Language
              </div>

              <% {
                en: { label: "English", flag: "🇬🇧" },
                ro: { label: "Română", flag: "🇷🇴" },
                fr: { label: "Français", flag: "🇫🇷" }
              }.each do |locale, data| %>
                <% if locale == I18n.locale.to_sym %>
                  <div class="flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-black bg-gray-50">
                    <span><%= data[:flag] %></span>
                    <span><%= data[:label] %></span>
                  </div>
                <% else %>
                  <%= link_to url_for(locale: locale),
                              class: "flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-black transition-colors duration-150" do %>
                    <span><%= data[:flag] %></span>
                    <span><%= data[:label] %></span>
                  <% end %>
                <% end %>
              <% end %>
            </div>
          </div>
        </details>
      </div>
    </div>
  </div>
</nav>
